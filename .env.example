# ── Required to run ──────────────────────────────
# Postgres with the pgvector extension (the docker-compose service provides this).
DATABASE_URL=postgresql://glovebox:glovebox@localhost:5432/glovebox
# `openssl rand -base64 32`
AUTH_SECRET=
# Base URL of the app (used by Auth.js for magic-link callbacks).
AUTH_URL=http://localhost:3000
# Core LLM (Claude). Without it, LLM-backed explanations run in a clearly-labeled
# offline fallback; the deterministic verbs (pricing, recall match, DTC, urgency) still work.
ANTHROPIC_API_KEY=
# Magic-link auth emails + reminder digests. Without it, magic links are printed to the
# server console (dev transport) and digests are logged instead of sent.
RESEND_API_KEY=
# From-address used for auth + digest emails (must be a verified Resend sender in prod).
EMAIL_FROM=GloveBox <login@glovebox.local>

# ── Optional (features degrade gracefully without) ──
# Whisper STT (voice capture) + embeddings. Without it: voice capture asks you to type,
# and embeddings use a local deterministic fallback so RAG still works offline.
OPENAI_API_KEY=
# Override the default Claude model.
LLM_MODEL=claude-sonnet-4-6
# Embedding model (OpenAI) when OPENAI_API_KEY is set.
EMBEDDING_MODEL=text-embedding-3-small

# S3-compatible object storage (receipts/photos/docs). Without these, a local ./storage dir is used.
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Background jobs in prod (the Inngest dev server needs none of these).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# SMS reminders (email works without this).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional paid parts/labor provider. The curated estimate model is used when absent.
PRICING_API_KEY=
